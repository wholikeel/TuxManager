     <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Utilization</string></property><property name="styleSheet"><string>color:#888;</string></property></widget></item>
     <item row="0" column="1"><widget class="QLabel" name="statUtilValue"><property name="text"><string>0%</string></property></widget></item>
