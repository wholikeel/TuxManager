    </layout>
   </item>

   <!-- Stats grid: 3 columns of label/value pairs -->
   <item>
    <layout class="QGridLayout" name="statsGrid">
     <property name="horizontalSpacing"><number>20</number></property>
     <property name="verticalSpacing"><number>6</number></property>

