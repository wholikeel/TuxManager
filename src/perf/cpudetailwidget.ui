       <property name="styleSheet"><string>font-size: 18pt; color: #aaccff;</string></property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Graph container — CpuGraphArea is inserted here at runtime -->
   <item>
    <widget class="QWidget" name="graphAreaContainer">
     <property name="minimumHeight"><number>180</number></property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
       <horstretch>0</horstretch>
       <verstretch>1</verstretch>
      </sizepolicy>
     </property>
